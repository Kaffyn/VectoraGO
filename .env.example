# Vectora AI - Configuration Example
# Copy this file to ~/.Vectora/.env and fill in your keys.

# ==========================================
# 🎯 CORE SETTINGS
# ==========================================
# Default provider to use (gemini, claude, openai, qwen, openrouter, anannas)
DEFAULT_PROVIDER=gemini
# Default model identifier
# Gemini: gemini-3.1-pro-preview
# Claude: claude-4.6-sonnet
# OpenAI: gpt-5.4
# OpenRouter: anthropic/claude-3.5-sonnet
DEFAULT_MODEL=gemini-3.1-pro-preview
# Log verbosity: debug, info, warn, error
LOG_LEVEL=info

# ==========================================
# 💎 OFFICIAL SDKs (Native Protocols)
# ==========================================
# Google Gemini (google.golang.org/genai)
GEMINI_API_KEY=AIzaSy...

# Anthropic Claude (github.com/anthropics/anthropic-sdk-go)
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI - Embeddings Only (github.com/austinfhunter/voyageai)
VOYAGE_API_KEY=pa-...

# OpenAI (github.com/openai/openai-go)
OPENAI_API_KEY=sk-proj-...
# Optional: point to a local proxy like LocalAI/vLLM
# OPENAI_BASE_URL=http://localhost:8080/v1

# ==========================================
# 🚀 GATEWAYS & AGGREGATORS (OpenAI Protocol)
# ==========================================
# OpenRouter (Unified access to all models)
OPENROUTER_API_KEY=sk-or-v1-...

# Anannas (Testing & Free APIs)
ANANNAS_API_KEY=your-anannas-key-here

# Qwen / Alibaba Cloud (via OpenAI-compatible mode)
QWEN_API_KEY=your-dashscope-key-here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==========================================
# 🏗️ MULTI-TENANCY (Advanced)
# ==========================================
# These keys are usually handled automatically by the Core per workspace.
