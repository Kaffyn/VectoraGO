{
  "name": "vectora",
  "displayName": "Vectora AI",
  "description": "Local AI coding assistant — RAG + agentic tools via ACP",
  "version": "0.1.0",
  "publishConfig": {
    "access": "restricted"
  },
  "publisher": "kaffyn",
  "license": "MIT",
  "readme": "README.md",
  "icon": "media/icon.ico",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kaffyn/Vectora.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "assistant",
    "coding",
    "rag",
    "agent",
    "local",
    "acp"
  ],
  "activationEvents": [
    "onView:vectora.chatView"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vectora.newSession",
        "title": "Vectora: Open Chat",
        "icon": "$(add)"
      },
      {
        "command": "vectora.explainCode",
        "title": "Vectora: Explain Code"
      },
      {
        "command": "vectora.refactorCode",
        "title": "Vectora: Refactor Code"
      },
      {
        "command": "vectora.toggleStatus",
        "title": "Vectora: Start/Stop Core"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vectora-sidebar",
          "title": "Vectora AI",
          "icon": "media/icon.ico"
        }
      ]
    },
    "views": {
      "vectora-sidebar": [
        {
          "type": "webview",
          "id": "vectora.chatView",
          "name": "Chat"
        }
      ]
    },
    "configuration": {
      "title": "Vectora",
      "properties": {
        "vectora.corePath": {
          "type": "string",
          "default": "vectora",
          "description": "Path to the Vectora core binary. Use 'vectora' if it's in your PATH."
        },
        "vectora.workspace": {
          "type": "string",
          "description": "Workspace folder for RAG indexing. Defaults to the first workspace folder."
        },
        "vectora.streaming": {
          "type": "boolean",
          "default": true,
          "description": "Enable streaming responses from the AI agent."
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "vectora.explainCode",
          "group": "vectora@1"
        },
        {
          "command": "vectora.refactorCode",
          "group": "vectora@2"
        }
      ]
    }
  },
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:webview && webpack --mode production",
    "watch": "webpack --mode development --watch",
    "compile-tests": "tsc",
    "lint": "eslint src",
    "package": "vsce package",
    "publish": "vsce publish",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:unit": "jest --config jest.config.js --testPathPattern=unit",
    "test:integration": "jest --config jest.config.js --testPathPattern=integration",
    "test:e2e": "jest --config jest.config.js --testPathPattern=e2e",
    "test:debug": "node --inspect-brk ./node_modules/.bin/jest --config jest.config.js --runInBand",
    "build:webview": "vite build",
    "dev:webview": "vite"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-portal": "^1.1.10",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.97.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "ansi-to-html": "^0.7.2",
    "axios": "^1.15.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "debounce": "^3.0.0",
    "diff": "^8.0.4",
    "fast-deep-equal": "^3.1.3",
    "fzf": "^0.5.2",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "i18next": "^26.0.4",
    "i18next-http-backend": "^3.0.4",
    "katex": "^0.16.45",
    "knuth-shuffle-seeded": "^1.0.6",
    "lru-cache": "^11.3.3",
    "lucide-react": "^0.453.0",
    "mermaid": "^11.14.0",
    "posthog-js": "^1.367.0",
    "pretty-bytes": "^7.1.0",
    "react": "^18.3.1",
    "react-compiler-runtime": "^1.0.0",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.2",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.1.0",
    "react-remark": "^2.1.0",
    "react-textarea-autosize": "^8.5.9",
    "react-use": "^17.6.0",
    "react-virtuoso": "^4.18.4",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remove-markdown": "^0.6.3",
    "shell-quote": "^1.8.3",
    "shiki": "^4.0.2",
    "stacktrace-js": "^2.0.2",
    "styled-components": "^6.4.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "unist-util-visit": "^5.1.0",
    "use-sound": "^5.0.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-material-icons": "^0.1.1",
    "vscrui": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@types/diff": "^7.0.2",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.8",
    "@types/katex": "^0.16.8",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/shell-quote": "^1.7.5",
    "@types/stacktrace-js": "^0.0.33",
    "@types/styled-components": "^5.1.36",
    "@types/vscode": "^1.90.0",
    "@types/vscode-webview": "^1.57.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^2.24.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "glob": "^10.3.12",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "mocha": "^10.4.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.10",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
