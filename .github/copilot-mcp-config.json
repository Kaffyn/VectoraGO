{
  "mcpServers": {
    "vectora": {
      "type": "stdio",
      "command": "/usr/local/bin/vectora",
      "args": ["mcp", "$GITHUB_WORKSPACE"],
      "tools": ["*"],
      "env": {
        "GEMINI_API_KEY": "${{ secrets.COPILOT_MCP_GEMINI_API_KEY }}",
        "OPENROUTER_API_KEY": "${{ secrets.COPILOT_MCP_OPENROUTER_API_KEY }}",
        "VOYAGE_API_KEY": "${{ secrets.COPILOT_MCP_VOYAGE_API_KEY }}"
      }
    }
  }
}
