# Vectora Local Test Environment
# Copy this to .env.local and fill with your API keys

# Gemini (Google)
GEMINI_API_KEY=

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Other providers (optional)
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROK_API_KEY=
QWEN_API_KEY=
VOYAGE_API_KEY=

# Test Configuration
VECTORA_LOG_LEVEL=info
VECTORA_MODE=test
TEST_TIMEOUT=30
TEST_VERBOSE=false
TEST_SAVE_OUTPUTS=true

# Defaults for testing
DEFAULT_PROVIDER=gemini
DEFAULT_MODEL=gemini-1.5-pro
TEST_WITH_GEMINI=true
